{
	"compilerOptions": {
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"module": "nodenext", // 或 "Node16"/"nodenext"
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"target": "ES2020",
		"strict": false,
		"noImplicitAny": false,
		"noImplicitThis": false,
		"outDir": "./dist",
		"rootDir": "./src"
	}
}